---
import Button from '@/components/Button.astro'
import Collapse from '@/components/Collapse.astro'
import Sponsors from '@/components/projects/Sponsors.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import PageLayout from '@/layouts/CommonPage.astro'
import { Image } from 'astro:assets'
import wechat from '@/assets/wechat-qrcode.png'
import alipay from '@/assets/alipay-qrcode.png'

const headings = [
  {
    depth: 2,
    slug: 'websites',
    text: 'Websites'
  },
  {
    depth: 2,
    slug: 'projects',
    text: 'Projects'
  },
  {
    depth: 2,
    slug: 'sponsorship',
    text: 'Sponsorship'
  }
]
---

<PageLayout title='Projects' headings={headings}>
  <p>Github Activities:</p>
  <p>
    <Image
      src='https://ghchart.rshah.org/659eb9/ethan2k04'
      alt='github activities'
      inferSize
      loading='eager'
      decoding='async'
    />
  </p>
  <p>
    If you think it would be useful or interesting to collaborate on a project, you can donate to
    support my work or contact me to discuss a project.
  </p>
  <Button title='Checkout sponsorship' class='w-fit' href='#sponsorship'>
    <svg class='size-5' slot='before'>
      <use href='/icons/copyright-sponsor.svg#mingcute-receive-money-line'></use>
    </svg>
  </Button>

  <h2 id='websites'>Websites</h2>
  <ProjectSection
    project={[
      {
        name: '🖥️ EthanSite',
        description: 'My personal site.',
        links: [
          { type: 'site', href: 'https://www.ethan2k04.icu/' }
        ]
      },
      {
        name: '🌎 Unifee-Global',
        description: 'A tuition fee map of QS top 150 universities.',
        links: [
          { type: 'site', href: 'https://unifee-global.com/' },
        ]
      }
    ]}
  />

  <h2 id='projects'>Projects</h2>
  <ProjectSection
    project={[
      {
        name: '🎾 TennisDetection',
        description: 'Tennis trajectory tracking system based on YOLO11',
        links: [{ type: 'github', href: 'https://github.com/Ethan2k04/TennisDetection' }]
      },
      {
        name: '⌨️ nku-compiler-2024-rs',
        description: 'A simple compiler written in Rust.',
        links: [
          { type: 'github', href: 'https://github.com/Ethan2k04/nku-compiler-2024-rs' },
          {
            type: 'doc',
            href: 'https://github.com/Ethan2k04/nku-compiler-2024-rs/blob/main/README.md'
          }
        ]
      }
    ]}
  />
  <Collapse title='Some old projects'>
    <ProjectSection
      project={[
        {
          name: '💻 NKUStar_TestBench',
          description: 'A simple CPU performance testbench',
          links: [{ type: 'github', href: 'https://github.com/Ethan2k04/NKUStar_TestBench' }]
        },
        {
          name: '😴 SleepFastApp',
          description: 'An android app that intergrate alarm clock with sleep monitoring.',
          links: [{ type: 'github', href: 'https://github.com/Ethan2k04/SleepFastApp' }]
        }
      ]}
    />
  </Collapse>

  <!-- sponsorship -->
  <h2 id="sponsorship" class="flex items-center">Sponsorship</h2>
  <p>Please leave a message or contact me proactively after sponsorship.</p>
  <div class='flex flex-col justify-center gap-4 sm:flex-row'>
    {
      [
        { name: 'WeChat', icon: 'mingcute-wechat-pay-line', image: wechat },
        { name: 'Alipay', icon: 'mingcute-alipay-line', image: alipay }
      ].map((item) => (
        <div class='group relative justify-center overflow-hidden rounded-xl border bg-white'>
          <div class='absolute bottom-0 end-0 start-0 top-0 flex items-center justify-center transition-opacity group-hover:opacity-0'>
            <svg class='size-20'>
              <use href={`/icons/copyright-sponsor.svg#${item.icon}`} />
            </svg>
          </div>
          <Image
            class='mx-auto my-0 max-w-72 opacity-30 blur-sm transition-opacity group-hover:opacity-100 group-hover:blur-none'
            src={item.image}
            alt={item.name}
            loading='eager'
          />
        </div>
      ))
    }
  </div>
  <p></p>
  or <a
      href="https://buymeacoffee.com/ethan2k04"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center"
      aria-label="Buy me a coffee"
      title="Buy me a coffee"
    >
      Buy me a coffee ☕
    </a>
</PageLayout>

